{
  "name": "@tenedev/biome-config",
  "version": "0.0.1-beta.0",
  "description": "Shared Biome configs",
  "keywords": [
    "biome",
    "config",
    "typescript",
    "eslint",
    "prettier",
    "shared-config",
    "monorepo",
    "code-quality",
    "linting",
    "formatting",
    "developer-tools",
    "best-practices",
    "code-style",
    "code-consistency",
    "code-maintenance"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/tenedev/biome-config.git"
  },
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/tenedev"
  },
  "license": "Apache-2.0",
  "author": "Sriman",
  "publishConfig": {
    "access": "public"
  },
  "packageManager": "pnpm@11.14.0",
  "files": [
    "configs"
  ],
  "main": "./configs/biome.json",
  "exports": {
    ".": "./configs/biome.json",
    "./off-fmt": "./configs/off-fmt.json"
  },
  "scripts": {
    "fmt": "prettier --write .",
    "fmt:check": "prettier --check .",
    "prepare": "husky"
  },
  "peerDependencies": {
    "@biomejs/biome": ">=2.4.0"
  },
  "devDependencies": {
    "@tenedev/prettier-config": "^1.3.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.6",
    "prettier": "^3.8.3"
  },
  "prettier": "@tenedev/prettier-config",
  "lint-staged": {
    "*": "prettier --write --ignore-unknown"
  }
}
